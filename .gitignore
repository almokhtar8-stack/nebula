# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.python-version

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
.mypy_cache/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Outputs ───────────────────────────────────────────────────────────────────
out/
*.pdf

# ── GENOMIC DATA — NEVER COMMIT ───────────────────────────────────────────────
# Real user genomic data must NEVER enter this repository.
# If any of these appear in a PR, the PR must be rejected immediately.
*.vcf
*.vcf.gz
*.bcf
*.bam
*.bam.bai
*.sam
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bed
*.ped
*.map
*.raw
!data/synthetic/*.vcf           # synthetic test VCF is explicitly allowed

# ── JSON output files (gitignored except test fixtures) ──────────────────────
*.json
!data/synthetic/*.json          # synthetic test metadata is allowed
!pyproject.toml                 # project config is allowed

# ── Surveillance outputs ──────────────────────────────────────────────────────
out/surveillance_queue.json
out/surveillance_notification.txt
out/surveillance_state.json
out/surveillance.log
data/review_log.jsonl
rulesets/pending_rules.yml

# ── Secrets and credentials ───────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
*.p12
secrets/
credentials/
*_secret*
*_private*

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
nebula.log
